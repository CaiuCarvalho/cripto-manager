# Supabase
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Blockchain APIs
ETHERSCAN_API_KEY=your-etherscan-api-key-here
MORALIS_API_KEY=your-moralis-api-key-here
SOLSCAN_API_KEY=your-solscan-api-key-here

# CoinGecko (optional - free tier does not require a key)
COINGECKO_API_KEY=

# Email
RESEND_API_KEY=your-resend-api-key-here

# Private key encryption — AES-256-GCM master key (32 bytes = 64 hex chars)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# KEEP THIS SECRET — never commit the real value, never store it in the database.
ENCRYPTION_KEY=your-64-char-hex-key-here

# Server
PORT=3001
NODE_ENV=development

# Frontend
FRONTEND_URL=http://localhost:3000
